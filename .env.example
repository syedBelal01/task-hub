# MongoDB (use your MongoDB Atlas connection string)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# If password has special chars, URL-encode them (e.g. @ → %40)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/taskhub?retryWrites=true&w=majority

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# App URL (for cookies and emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail SMTP (for signup verification emails)
# Use App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Optional: Google Calendar OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
